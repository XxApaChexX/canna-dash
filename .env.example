PORT=5050
# Same secret as STORE_WEBHOOK_SECRET on Render (delivery-dispatch-mvp). Set in Vercel project env too.
DELIVERY_WEBHOOK_SECRET=replace-with-long-random-secret
# Dispatch API (Render). NOT your Canna Dash Vercel URL (e.g. canna-dash-*.vercel.app).
DELIVERY_API_BASE_URL=https://delivery-dispatch-mvp.onrender.com
# Optional: "Dispatch board" link on storefront (defaults to DELIVERY-style URL if unset).
PUBLIC_DISPATCH_BOARD_URL=https://delivery-dispatch-mvp.onrender.com
